# DEEPSEEK_API_KEY: Required for DeepSeek Official API calls
# Get your API key from https://api.deepseek.com
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"

# DEEPSEEK_MODEL: The model to use via DeepSeek Official API
# Common values: deepseek-chat
DEEPSEEK_MODEL="deepseek-chat"

# Optional: custom base url (e.g. proxy/gateway)
# DEEPSEEK_BASE_URL="https://api.deepseek.com"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
